# ─── JARVIS v2 — Variables de Entorno ─────────────────────────────────────────

# ── API Keys ───────────────────────────────────────────────────────────────────
# LLMs (configurar al menos uno)
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
GOOGLE_API_KEY=AIza...

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ALLOWED_USERS=123456789,987654321

# ── WhatsApp ───────────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=...
WHATSAPP_WEBHOOK_VERIFY=jarvis_secret_token
WHATSAPP_PHONE_NUMBER_ID=123456789

# ── WhatsApp / Evolution API ────────────────────────────────────────────────────
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE_NAME=jarvis-instance

# ── WhatsApp Number ────────────────────────────────────────────────────────────
WA_NUMBER=+5491112345678

# ── Landing Builder ─────────────────────────────────────────────────────────────
PUBLIC_URL=https://tu-dominio.com
LANDINGS_DIR=/opt/jarvis/landings

# ── Browser Control ──────────────────────────────────────────────────────────────
# Dejar vacío para usar solo el servidor headless (modo por defecto)
WINDOWS_AGENT_URL=http://192.168.1.X:3001
WINDOWS_AGENT_SECRET=cambia-esto-por-un-secreto
SCREENSHOTS_DIR=/tmp/jarvis-screenshots

# ── Self-Repair ──────────────────────────────────────────────────────────────────
BACKUPS_DIR=/opt/jarvis/backups
JARVIS_ROOT=/opt/jarvis/jarvis-v2

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=production

# ── Database ───────────────────────────────────────────────────────────────────
DB_DIR=/opt/jarvis/data/db

# ── Facebook / Meta ────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=EAAxxxxx...
META_APP_ID=123456789
META_APP_SECRET=xxxxx...

# ── Google Workspace ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=https://tu-dominio.com/oauth/callback

# ── N8N ───────────────────────────────────────────────────────────────────────
N8N_URL=https://n8n.tu-dominio.com
N8N_API_KEY=xxxxx

# ── Binancia ───────────────────────────────────────────────────────────────────
BINANCE_API_KEY=xxxxx
BINANCE_SECRET_KEY=xxxxx
