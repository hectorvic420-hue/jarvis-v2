{
  "name": "jarvis-v2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "npm run build && ./scripts/deploy.sh",
    "restart": "./scripts/restart.sh",
    "setup-server": "./scripts/setup-server.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:security": "vitest run tests/security/",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "grammy": "^1.30.0",
    "groq-sdk": "^0.9.1",
    "mammoth": "^1.12.0",
    "openai": "^4.47.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.43.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.7",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
